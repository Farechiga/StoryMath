{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryMath Problem Instance",
  "type": "object",
  "required": [
    "id",
    "metadata",
    "story",
    "quantities",
    "steps",
    "operatorExperiments",
    "visualizations"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "required": [
        "title",
        "theme",
        "gradeBand",
        "factualStatus"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "theme": {
          "type": "string"
        },
        "gradeBand": {
          "type": "string"
        },
        "factualStatus": {
          "enum": [
            "verified",
            "fictionalized",
            "inspired_by"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "story": {
      "type": "object",
      "required": [
        "brief",
        "causalEvent",
        "causalChain"
      ],
      "properties": {
        "brief": {
          "type": "string"
        },
        "causalEvent": {
          "type": "string"
        },
        "causalChain": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2
        },
        "curiosityNote": {
          "type": "string"
        }
      }
    },
    "quantities": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "semanticRole",
          "label",
          "unit",
          "value",
          "visibility"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "semanticRole": {
            "type": "string"
          },
          "label": {
            "type": "object",
            "required": [
              "child",
              "compact",
              "semanticChips"
            ],
            "properties": {
              "child": {
                "type": "string"
              },
              "compact": {
                "type": "string"
              },
              "semanticChips": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "unit": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "visibility": {
            "enum": [
              "given",
              "find",
              "revealed_after_step"
            ]
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "order",
          "goalQuantityId",
          "relationshipTemplateId",
          "acceptedEquationFormIds",
          "preferredEquationFormId",
          "operatorOptions",
          "expectedDirection",
          "prompt",
          "backwardCheck"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "goalQuantityId": {
            "type": "string"
          },
          "relationshipTemplateId": {
            "type": "string"
          },
          "acceptedEquationFormIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preferredEquationFormId": {
            "type": "string"
          },
          "operatorOptions": {
            "type": "array",
            "items": {
              "enum": [
                "+",
                "-",
                "\u00d7",
                "\u00f7"
              ]
            },
            "minItems": 2
          },
          "expectedDirection": {
            "enum": [
              "increase",
              "decrease",
              "combine",
              "split",
              "scale"
            ]
          },
          "prompt": {
            "type": "string"
          },
          "reasoningPrompt": {
            "type": "string"
          },
          "backwardCheck": {
            "type": "object",
            "required": [
              "required",
              "prompt",
              "acceptedEquationFormIds"
            ],
            "properties": {
              "required": {
                "type": "boolean"
              },
              "prompt": {
                "type": "string"
              },
              "acceptedEquationFormIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "operatorExperiments": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "operator",
          "stepId",
          "operandQuantityIds",
          "hypotheticalTargetQuantityId",
          "narrativeFit",
          "directionProduced",
          "headline",
          "explanation",
          "worldIfTrue"
        ],
        "properties": {
          "operator": {
            "enum": [
              "+",
              "-",
              "\u00d7",
              "\u00f7"
            ]
          },
          "stepId": {
            "type": "string"
          },
          "operandQuantityIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 2,
            "maxItems": 2
          },
          "hypotheticalTargetQuantityId": {
            "type": "string"
          },
          "narrativeFit": {
            "enum": [
              "actual",
              "counterfactual",
              "different_question"
            ]
          },
          "directionProduced": {
            "enum": [
              "increase",
              "decrease",
              "combine",
              "split",
              "scale"
            ]
          },
          "headline": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          },
          "worldIfTrue": {
            "type": "string"
          }
        }
      }
    },
    "visualizations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "quantityIds"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "comparison_bar",
              "part_whole_bar",
              "change_bar"
            ]
          },
          "quantityIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}